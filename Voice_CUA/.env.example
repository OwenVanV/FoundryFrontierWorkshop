# ============================================================================
# Voice + CUA Workshop — Environment Configuration
# ============================================================================

# Authentication Mode
# Set to "true" to use Managed Identity / Bearer token auth.
# Set to "false" to use API key auth (default).
# When true: Voice Live uses Bearer token, CUA uses DefaultAzureCredential.
# When false: api-key headers are used for Voice Live, API key for CUA.
USE_MANAGED_IDENTITY=true

# Azure AI Foundry Resource (for Voice Live API)
# Can be just the resource name OR a full URL — both work:
#   AZURE_AI_RESOURCE_NAME=owenv-foundry-resource
#   AZURE_AI_RESOURCE_NAME=https://owenv-foundry-resource.services.ai.azure.com/...
AZURE_AI_RESOURCE_NAME=your-resource-name
AZURE_AI_API_KEY=your-api-key

# Voice Live model (gpt-5, gpt-4o, gpt-4.1, etc.)
VOICE_LIVE_MODEL=gpt-5

# CUA Configuration (for shadowbox system)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2025-03-01-preview
CUA_MODEL=gpt-5.4
SUPERVISOR_MODEL=gpt-4.1

# Docker container name for CUA
DOCKER_CONTAINER_NAME=shadowboxer-vnc
DOCKER_DISPLAY=:99
