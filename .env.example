# ============================================================================
# PayPal x Azure AI Workshop — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your Azure deployment details.
# NEVER commit .env to version control.
# ============================================================================

# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Azure AI Foundry (optional — used in Module 04)
AZURE_AI_FOUNDRY_ENDPOINT=https://your-foundry.cognitiveservices.azure.com/
AZURE_AI_FOUNDRY_API_KEY=your-foundry-key-here
AZURE_AI_FOUNDRY_DEPLOYMENT=gpt-4o

# Azure Monitor / Application Insights (used in Module 06)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# Authentication Mode
# Set to "true" to use Managed Identity / DefaultAzureCredential (production).
# Set to "false" to use API keys (default, simpler for workshops).
# When true: run `az login` locally, or use Managed Identity on Azure.
# When false: AZURE_OPENAI_API_KEY is required.
USE_MANAGED_IDENTITY=false

# Workshop Configuration
# Set to "true" to enable detailed telemetry export to Azure Monitor.
# Set to "false" for local-only telemetry (console output).
ENABLE_AZURE_MONITOR=false
