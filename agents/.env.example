# ============================================================================
# Agents Deep-Dive — Environment Configuration
# ============================================================================
# Copy to .env and fill in your values.
# ============================================================================

# Authentication Mode
# Set to "true" to use Managed Identity / DefaultAzureCredential.
# Set to "false" to use `az login` (DefaultAzureCredential still, but explicit).
# Foundry SDKs always use credential objects — `az login` is required either way.
# On Azure (VMs, App Service, AKS), Managed Identity is auto-detected.
USE_MANAGED_IDENTITY=false

# Microsoft Foundry Project (used by both MAF and Foundry Agent Service)
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com
FOUNDRY_MODEL=gpt-5.2-chat

# Foundry Agent Service specific (Module 01, 03)
# The project endpoint above is also used here.

# MAF specific (Module 02, 04, 05)
# Uses FOUNDRY_PROJECT_ENDPOINT and FOUNDRY_MODEL above.

# Azure Authentication
# Run `az login` before running any module. DefaultAzureCredential is used throughout.
