# ──────────────────────────────────────────────────────────────
# Shadowbox CUA Accelerator — Environment Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ─── Endpoint (choose one) ───────────────────────────────────
# "azure" = Azure OpenAI   |   "openai" = OpenAI direct
CUA_ENDPOINT=azure
# ─── Authentication ───────────────────────────────────
# Set to "true" to use DefaultAzureCredential (az login / Managed Identity)
# Set to "false" to use API key (AZURE_OPENAI_API_KEY required)
USE_MANAGED_IDENTITY=false
# ─── Azure OpenAI (required if CUA_ENDPOINT=azure) ──────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# ─── OpenAI (required if CUA_ENDPOINT=openai) ───────────────
# OPENAI_API_KEY=sk-...

# ─── Model ───────────────────────────────────────────────────
CUA_MODEL=gpt-5.4

# ─── Supervisor model (used to guide the CUA agent) ─────────
SUPERVISOR_MODEL=gpt-4.1

# ─── Docker container settings ──────────────────────────────
DOCKER_CONTAINER_NAME=shadowboxer-vnc
DOCKER_DISPLAY=:99

# ─── Run settings ───────────────────────────────────────────
# Max CUA loop iterations before stopping
CUA_MAX_ITERATIONS=50
# Max times the supervisor responds before auto-terminating
CUA_MAX_USER_INPUTS=3
